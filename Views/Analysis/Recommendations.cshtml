@{
    ViewData["Title"] = "Recommendations";
}

<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
        <a class="navbar-brand" asp-area="" asp-controller="Analysis" asp-action="AnalysisHome">Analysis Home</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Analysis" asp-action="AnalyzeData">Analyze Data</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Analysis"
                       asp-action="Recommendations">Recommendations</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-header bg-success bg-gradient text-white ">Select User</div>
                <div class="list-group list-group-flush" id="userList"></div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="row">
                <div class="col-md-6">
                    <h1 class="display-3">Diet</h1>
                    <h4 class="fw-bold mt-3">Problems</h4>
                    <ul id="dietProblems" class="fs-5"></ul>

                    <h4 class="fw-bold mt-4">Recommendations</h4>
                    <ul id="dietRecs" class="fs-5"></ul>
                </div>

                <div class="col-md-6">
                    <h1 class="display-3">Exercise</h1>
                    <h4 class="fw-bold mt-3">Problems</h4>
                    <ul id="exerciseProblems" class="fs-5"></ul>

                    <h4 class="fw-bold mt-4">Recommendations</h4>
                    <ul id="exerciseRecs" class="fs-5"></ul>
                </div>
            </div>

            <hr class="my-5" />

            <div class="row">
                <div class="col-12">
                    <h1 class="display-3">Recommended Lifestyle</h1>
                    <ul id="lifestyleRecs" class="fs-5 mt-3"></ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // 1. Data Source (Same arrays as the Analyze page)
    const userData = [
        {
            name: "Minh",
            diet: [10, 12, 11, 13, 12, 11, 45], // Outlier triggers rejection
            exercise: [5, 7, 6, 8, 5, 7, 6]     // Stable
        },
        {
            name: "Long",
            diet: [15, 16, 15, 17, 16, 15, 16], // Stable
            exercise: [10, 12, 11, 13, 12, 11, 45]  // Drop triggers rejection
        },
        {
            name: "Vu",
            diet: [15, 16, 15, 17, 16, 15, 16], // Stable
            exercise: [5, 7, 6, 8, 5, 7, 6]  // Drop triggers rejection
        }
    ];

    // 2. The Recommendation "Library"
    const infoMap = {
        diet: {
            problem: ["Excess body fat", "Irregular caloric intake", "Lack of vegetable nutrients"],
            recommendation: ["Eat less sugar and meat", "Prioritize leafy greens", "Standardize meal timings"]
        },
        exercise: {
            problem: ["Inconsistent repetition range", "Workout duration is too long", "Overtraining/Fatigue detected"],
            recommendation: ["Increase repetitions to 10", "Reduce set weights", "Focus on cardiovascular recovery"]
        }
    };

    function init() {
        const list = document.getElementById('userList');
        userData.forEach((user, i) => {
            const btn = document.createElement('button');
            btn.className = "list-group-item user-item"; 
            btn.textContent = user.name;
            btn.onclick = () => {
                document.querySelectorAll('.user-item').forEach(e => e.classList.remove('active'));
                btn.classList.add('active');
                generateDynamicContent(user);
            };
            list.appendChild(btn);
        });
        list.firstChild.click();
    }

    function generateDynamicContent(user) {
        // Run Hypothesis for Diet
        const dietResult = analyzeHypothesis(user.diet);
        updateSection('diet', dietResult);

        // Run Hypothesis for Exercise
        const exerciseResult = analyzeHypothesis(user.exercise);
        updateSection('exercise', exerciseResult);

        // Lifestyle Summary
        const lifestyleEl = document.getElementById('lifestyleRecs');
        if (dietResult.isRejected || exerciseResult.isRejected) {
            lifestyleEl.innerHTML = "<li>Lifestyle 1: Active intervention required. Adjust diet and cardio immediately.</li>";
        } else {
            lifestyleEl.innerHTML = "<li>Lifestyle 2: Maintain current routine. Data shows healthy stability.</li>";
        }
    }

    function analyzeHypothesis(data) {
        const n = data.length;
        const mean = data.reduce((a, b) => a + b) / n;
        const stdDev = Math.sqrt(data.map(x => Math.pow(x - mean, 2)).reduce((a, b) => a + b) / n) || 1;
        const zScore = (data[n - 1] - mean) / stdDev;
        
        // Alpha = 0.05 -> Z = 1.96
        return { isRejected: Math.abs(zScore) > 1.96 };
    }

    function updateSection(type, result) {
        const probEl = document.getElementById(type + 'Problems');
        const recEl = document.getElementById(type + 'Recs');

        if (result.isRejected) {
            probEl.innerHTML = infoMap[type].problem.map(p => `<li>${p}</li>`).join('');
            recEl.innerHTML = infoMap[type].recommendation.map(r => `<li>${r}</li>`).join('');
        } else {
            probEl.innerHTML = "<li class='text-muted'>No significant problems detected.</li>";
            recEl.innerHTML = "<li class='text-muted'>Keep up the current habit.</li>";
        }
    }

    init();
</script>
}