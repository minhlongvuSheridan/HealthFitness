@model HealthFitness.Models.Exercise

@{
    ViewData["Title"] = "Exercise Info";
}

<div class="container py-5">
    <div class="mb-4">
        <a href="@Url.Action("ExerciseHome", "Exercise")" class="btn btn-outline-dark">
            ← Back to Exercise Home
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-6">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid w-100 h-100"
                         style="object-fit: cover; min-height: 400px;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center h-100" style="min-height: 400px;">
                        <span class="text-muted fs-5">No Image Available</span>
                    </div>
                }
            </div>

            <div class="col-lg-6">
                <div class="card-body p-4 p-lg-5">
                    <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>
                    <p class="lead text-muted">@Model.Description</p>

                    <div class="mb-4">
                        <span class="badge bg-primary fs-6 me-2">@Model.BodyPart</span>
                        <span class="badge bg-success fs-6 me-2">@Model.Goal</span>
                        <span class="badge bg-warning text-dark fs-6 me-2">@Model.Difficulty</span>
                    </div>

                    <div class="mb-3">
                        <p><strong>Target Muscle:</strong> @Model.TargetMuscle</p>
                        <p><strong>Equipment:</strong> @Model.Equipment</p>
                        <p><strong>Location:</strong> @Model.Location</p>
                    </div>

                    <hr />

                    <h4 class="fw-bold">Instructions</h4>
                    <p>@Model.Instructions</p>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.YouTubeVideoId))
    {
        <div class="card shadow-sm border-0 rounded-4 mt-5">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-3">Tutorial Video</h3>
                <div class="ratio ratio-16x9">
                    <iframe src="https://www.youtube.com/embed/@(Model.YouTubeVideoId)" title="@Model.Name Tutorial"
                            allowfullscreen loading="lazy"></iframe>
                </div>
            </div>
        </div>
    }

    @if (Model.Images != null && Model.Images.Any())
    {
        <div class="mt-5">
            <h3 class="fw-bold mb-4">More Images</h3>
            <div class="row g-4">
                @foreach (var image in Model.Images)
                {
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                            <img src="@image.ImagePath" alt="@Model.Name" class="img-fluid"
                                 style="height: 250px; object-fit: cover;" />
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>