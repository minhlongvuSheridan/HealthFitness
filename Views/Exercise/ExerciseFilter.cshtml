@model IEnumerable<HealthFitness.Models.Exercise>

@{
    ViewData["Title"] = "Exercise Filter";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <h1 class="display-4 fw-bold">Filtered Exercises</h1>
        <p class="lead text-muted">Browse the exercises that match your selected filters.</p>
    </div>

    <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
        @if (!string.IsNullOrEmpty(ViewBag.SelectedBodyPart))
        {
            <span class="badge bg-primary fs-6">Body Part: @ViewBag.SelectedBodyPart</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.SelectedGoal))
        {
            <span class="badge bg-success fs-6">Goal: @ViewBag.SelectedGoal</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.SelectedDifficulty))
        {
            <span class="badge bg-warning text-dark fs-6">Difficulty: @ViewBag.SelectedDifficulty</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.SelectedEquipment))
        {
            <span class="badge bg-secondary fs-6">Equipment: @ViewBag.SelectedEquipment</span>
        }
    </div>

    <div class="text-center mb-4">
        <a href="@Url.Action("ExerciseHome", "Exercise")" class="btn btn-outline-dark">
            ← Back to Exercise Home
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm rounded-4 p-4">
            <h4 class="fw-bold">No exercises found</h4>
            <p class="mb-0">Try changing your filters and searching again.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var exercise in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        @if (!string.IsNullOrEmpty(exercise.ImageUrl))
                        {
                            <img src="@exercise.ImageUrl" class="card-img-top rounded-top-4" alt="@exercise.Name"
                                 style="height: 220px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center rounded-top-4"
                                 style="height: 220px;">
                                <span class="text-muted">No Image Available</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h4 class="card-title fw-bold">@exercise.Name</h4>
                            <p class="text-muted mb-2">@exercise.Description</p>

                            <div class="mb-3">
                                <span class="badge bg-primary me-1">@exercise.BodyPart</span>
                                <span class="badge bg-success me-1">@exercise.Goal</span>
                                <span class="badge bg-warning text-dark me-1">@exercise.Difficulty</span>
                            </div>

                            <p class="mb-1"><strong>Equipment:</strong> @exercise.Equipment</p>
                            <p class="mb-3"><strong>Location:</strong> @exercise.Location</p>

                            <div class="mt-auto">
                                <a href="@Url.Action("ExerciseInfo", "Exercise", new { id = exercise.Id })"
                                       class="btn btn-primary w-100">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>